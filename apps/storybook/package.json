{
  "name": "@mctlhq/storybook",
  "version": "0.1.0",
  "private": true,
  "description": "MCTL design system showcase",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "build:storybook": "storybook build -o storybook-static",
    "typecheck": "tsc --noEmit",
    "lint": "eslint stories .storybook",
    "clean": "rm -rf storybook-static .turbo"
  },
  "dependencies": {
    "@mctlhq/css": "workspace:*",
    "@mctlhq/tokens": "workspace:*",
    "@mctlhq/ui": "workspace:*"
  },
  "devDependencies": {
    "@storybook/vue3-vite": "^9.0.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "storybook": "^9.0.0",
    "vite": "^5.4.10",
    "vue": "^3.5.12"
  }
}
