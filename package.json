{
  "name": "@mctlhq/design",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "MCTL shared design system — tokens, CSS, Vue 3 components and Storybook showcase",
  "license": "Apache-2.0",
  "homepage": "https://ui.mctl.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/mctlhq/mctl-design.git"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "build:storybook": "turbo run build:storybook",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
